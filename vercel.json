{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/b&w",
      "destination": "https://script.google.com/macros/s/AKfycbxsYY48xaZk3No8lKQ3pXo9cqTV6x4NaLeCQQUrC2-exHK9hsgcfwoB3-3cir9HhSwm/exec",
      "statusCode": 302
    },
    {
      "source": "/",
      "destination": "https://rejig.ai",
      "statusCode": 302
    }
  ],
  "crons": [
    {
      "path": "/api/cron/weekly",
      "schedule": "0 5 * * 0"
    }
  ],
  "functions": {
    "src/app/api/cron/bi/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/import-rejig/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/weekly/route.ts": {
      "maxDuration": 300
    }
  }
}
