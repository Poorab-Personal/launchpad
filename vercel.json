{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "https://rejig.ai",
      "statusCode": 302
    }
  ],
  "crons": [
    {
      "path": "/api/cron/weekly",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/cron/daily-checks",
      "schedule": "0 16 * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/bi/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/import-rejig/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/weekly/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/daily-checks/route.ts": {
      "maxDuration": 300
    }
  }
}
